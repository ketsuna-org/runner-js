{
  "name": "runner-js",
  "version": "0.1.0",
  "description": "Bot Creator JS Runner — HTTP handler for pure JavaScript Discord bots",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pkg:linux-x64": "pkg dist/index.js --config pkg.config.json --targets node22-linux-x64 --output build/bot-creator-runner-js-linux-x64",
    "pkg:linux-arm64": "pkg dist/index.js --config pkg.config.json --targets node22-linux-arm64 --output build/bot-creator-runner-js-linux-arm64",
    "pkg:win-x64": "pkg dist/index.js --config pkg.config.json --targets node22-win-x64 --output build/bot-creator-runner-js-win.exe"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.18.0",
    "@snazzah/davey": "^0.1.6",
    "bufferutil": "^4.0.9",
    "canvas": "^3.1.0",
    "discord.js": "^14.21.0",
    "fastify": "^5.4.0",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.15",
    "sodium-native": "^4.3.3",
    "zlib-sync": "^0.1.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@yao-pkg/pkg": "^6.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
